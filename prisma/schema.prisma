// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Authentication Models (Required by Auth.js v5)
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom business logic relations
  role          String    @default("STAFF") // ADMIN, STAFF
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Business Models
model Lead {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clientName  String
  email       String?
  phone       String?
  amount      Float?
  status      String   @default("Inquiry") // Inquiry, Site Visit, Negotiation, Booked, Completed
  date        DateTime @default(now())
  notes       String?
  eventType   String?
  guests      Int?
}

model Invoice {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String   @unique
  clientName    String
  clientEmail   String
  clientAddress String
  items         Json     // Store as JSON for flexibility
  subtotal      Float
  taxAmount     Float
  total         Float
  status        String   @default("Draft") // Draft, Sent, Paid
  date          DateTime @default(now())
  dueDate       DateTime?
}

model Expense {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  amount      Float
  category    String   // Venue, Catering, Decoration, Utilities, Other
  vendor      String?
  date        DateTime @default(now())
  status      String   @default("Paid")
}
